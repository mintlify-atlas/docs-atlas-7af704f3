  "keyFeatures": [
    "Dependency tracking with four relationship types (blocks, parent-child, related, discovered-from)",
    "Multi-agent coordination via comments and auto-assignment",
    "Ready work detection to find unblocked tasks",
    "Git-friendly JSONL export/import",
    "JSON output for programmatic access",
    "SQLite storage with auto-discovery",
    "Dependency tree visualization and cycle detection",
    "Status tracking (open, in_progress, blocked, closed)",
    "Priority levels and issue types",
    "Audit trail with full event history"
  ],
  "publicApiSurface": [
    "tracer init - Initialize tracker in project",
    "tracer create - Create new issue",
    "tracer list - List issues with filters",
    "tracer show - Show issue details",
    "tracer update - Update issue status",
    "tracer close - Close one or more issues",
    "tracer comment - Add comment to issue",
    "tracer ready - Find unblocked work",
    "tracer blocked - Find blocked issues",
    "tracer dep add - Add dependency",
    "tracer dep remove - Remove dependency",
    "tracer dep tree - Show dependency tree",
    "tracer dep cycles - Detect dependency cycles",
    "tracer stats - Show project statistics",
    "tracer export - Export to JSONL",
    "tracer import - Import from JSONL",
    "tracer learn - Learn tracer concepts"
  ]
}
